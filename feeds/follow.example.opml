<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>AI News Radar RSS Example</title>
  </head>
  <body>
    <outline text="Official AI Sources">
      <outline
        text="OpenAI News"
        title="OpenAI News"
        type="rss"
        xmlUrl="https://openai.com/news/rss.xml"
        htmlUrl="https://openai.com/news"
      />
      <outline
        text="Hugging Face Blog"
        title="Hugging Face Blog"
        type="rss"
        xmlUrl="https://huggingface.co/blog/feed.xml"
        htmlUrl="https://huggingface.co/blog"
      />
    </outline>
    <outline text="AI Media and Builders">
      <outline
        text="Wired AI"
        title="Wired AI"
        type="rss"
        xmlUrl="https://www.wired.com/feed/tag/ai/latest/rss"
        htmlUrl="https://www.wired.com/tag/artificial-intelligence/"
      />
      <outline
        text="InfoQ CN"
        title="InfoQ CN"
        type="rss"
        xmlUrl="https://www.infoq.cn/feed"
        htmlUrl="https://www.infoq.cn/"
      />
      <outline
        text="宝玉"
        title="宝玉"
        type="rss"
        xmlUrl="https://baoyu.io/feed.xml"
        htmlUrl="https://baoyu.io/"
      />
      <outline
        text="Simon Willison"
        title="Simon Willison"
        type="rss"
        xmlUrl="https://simonwillison.net/atom/everything/"
        htmlUrl="https://simonwillison.net/"
      />
    </outline>
    <outline text="AI Newsletters">
      <outline
        text="AI For Developers"
        title="AI For Developers"
        type="rss"
        xmlUrl="https://aifordevelopers.substack.com/feed"
        htmlUrl="https://aifordevelopers.substack.com/"
      />
      <outline
        text="True Positive Weekly"
        title="True Positive Weekly"
        type="rss"
        xmlUrl="https://aiweekly.substack.com/feed"
        htmlUrl="https://aiweekly.substack.com/"
      />
      <outline
        text="AI Evaluation"
        title="AI Evaluation"
        type="rss"
        xmlUrl="https://aievaluation.substack.com/feed"
        htmlUrl="https://aievaluation.substack.com/"
      />
      <outline
        text="BuzzRobot"
        title="BuzzRobot"
        type="rss"
        xmlUrl="https://buzzrobot.substack.com/feed"
        htmlUrl="https://buzzrobot.substack.com/"
      />
    </outline>
  </body>
</opml>
